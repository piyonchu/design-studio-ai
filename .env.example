# ---- Database (Postgres + pgvector) ----
POSTGRES_USER=designstudio
POSTGRES_PASSWORD=designstudio
POSTGRES_DB=design_studio
POSTGRES_PORT=5432
DATABASE_URL=postgres://designstudio:designstudio@localhost:5432/design_studio

# ---- Backend ----
RUST_LOG=info,tower_http=debug
# Set true in production (HTTPS) so the session cookie carries the Secure flag.
COOKIE_SECURE=false

# ---- Rate limiting (per IP, in-memory) ----
# Global API limit: ~RATE_LIMIT_RPS req/s, up to RATE_LIMIT_BURST outstanding.
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60
# Stricter auth limit: burst of AUTH_RATE_LIMIT_BURST, then 1 every PERIOD secs.
AUTH_RATE_LIMIT_PERIOD_SECS=6
AUTH_RATE_LIMIT_BURST=10

# ---- AI providers ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=medium
# AI_MOCK=true returns canned, schema-valid DSL with no network/key (free dev).
# Set false + provide ANTHROPIC_API_KEY for real generation.
AI_MOCK=true

# ---- Asset image generation (OpenRouter) ----
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# ASSET_MOCK=true returns placeholder images (picsum) with no key/cost.
# Set false + provide OPENROUTER_API_KEY for real image generation.
ASSET_MOCK=true

# ---- Object storage (AWS S3) ----
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ---- Bot protection ----
TURNSTILE_SECRET_KEY=

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8080
