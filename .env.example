# ---- Database (Postgres + pgvector) ----
POSTGRES_USER=designstudio
POSTGRES_PASSWORD=designstudio
POSTGRES_DB=design_studio
POSTGRES_PORT=5432
DATABASE_URL=postgres://designstudio:designstudio@localhost:5432/design_studio

# ---- Backend ----
RUST_LOG=info,tower_http=debug
# Set true in production (HTTPS) so the session cookie carries the Secure flag.
COOKIE_SECURE=false
# CORS: leave empty for a permissive dev policy. In production set a
# comma-separated origin allowlist (then credentials are allowed), e.g.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=

# ---- Server ----
# Port to listen on. Most PaaS (Cloud Run, etc.) inject $PORT; default 8080.
PORT=8080

# ---- Async job queue ----
# JOBS_WORKER=false disables the in-process worker (e.g. on a scale-to-zero host
# where a scheduler drains the queue instead). Default: enabled.
JOBS_WORKER=true
# Shared secret for POST /internal/jobs/drain (Cloud Scheduler / cron). Leave
# empty to disable that endpoint (returns 404). See DEPLOY.md.
JOBS_DRAIN_SECRET=

# ---- Rate limiting (per IP, in-memory) ----
# Global API limit: ~RATE_LIMIT_RPS req/s, up to RATE_LIMIT_BURST outstanding.
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60
# Stricter auth limit: burst of AUTH_RATE_LIMIT_BURST, then 1 every PERIOD secs.
AUTH_RATE_LIMIT_PERIOD_SECS=6
AUTH_RATE_LIMIT_BURST=10

# ---- Asset image generation (OpenRouter) ----
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# ASSET_MOCK=true returns placeholder images (picsum) with no key/cost.
# Set false + provide OPENROUTER_API_KEY for real image generation.
ASSET_MOCK=true

# ---- LLM answer synthesis ("Ask this project") ----
# LLM_MOCK=true (default) returns a templated answer — no key, no cost.
# Set false + OPENROUTER_API_KEY for real synthesis via a cheap text model.
LLM_MOCK=true
OPENROUTER_LLM_MODEL=google/gemini-2.5-flash
# Disk cache for AI outputs (LLM answers): identical calls are never re-paid.
AI_CACHE_DIR=./.ai-cache

# ---- Usage / credit visibility ----
# GET /usage surfaces the shared OpenRouter key's remaining credit (dev). With a
# key present it fetches the live value (cached 60s); set USAGE_MOCK=true (or
# leave the key empty) for a placeholder — used in CI.
USAGE_MOCK=false

# ---- Embeddings (smart search / dedup / RAG) ----
# EMBED_MOCK=true (default) uses a free feature-hashed embedder (lexical).
# Set false + OPENROUTER_API_KEY for real semantic embeddings (cheap, cached).
EMBED_MOCK=true
EMBED_MODEL=openai/text-embedding-3-small

# ---- Audio generation ----
# AUDIO_MOCK=true (default) synthesizes a short placeholder WAV — no cost, no
# network. No hosted audio provider is wired yet; set false only once one is.
AUDIO_MOCK=true

# ---- Object storage (S3 / MinIO) ----
# Generated assets are stored as objects and served via GET /assets/:id/file.
# Local dev uses the bundled MinIO (docker compose). Leave S3_BUCKET empty to
# fall back to inline storage (data URLs in the DB) — no object store required.
S3_BUCKET=design-studio-assets
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Point at MinIO for local dev; leave empty to use real AWS S3 endpoints.
S3_ENDPOINT=http://localhost:9000
# MinIO needs path-style addressing (bucket in the path, not the host).
S3_PATH_STYLE=true
# Local MinIO ports (docker compose): S3 API + web console.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Bot protection ----
TURNSTILE_SECRET_KEY=

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8080
